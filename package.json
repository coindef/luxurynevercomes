{
  "name": "luxurynevercomes",
  "description": "富了个寂寞 · 模拟购买奢侈品治愈\"买不起\"——不扣钱，不发货，只发多巴胺",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "author": "Jiuqiao Yu <jiuqiao_yu@berkeley.edu>",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "images": "node --import ./scripts/ts-resolve.mjs scripts/gen-images.mjs --breadth",
    "images:openai": "node --import ./scripts/ts-resolve.mjs scripts/gen-images.mjs --provider openai --breadth",
    "images:fal": "node --import ./scripts/ts-resolve.mjs scripts/gen-images.mjs --provider fal --breadth",
    "images:plan": "node --import ./scripts/ts-resolve.mjs scripts/gen-images.mjs --plan",
    "images:manifest": "node --import ./scripts/ts-resolve.mjs scripts/build-image-manifest.mjs",
    "images:aspect": "node scripts/normalise-aspect.mjs"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "tailwindcss": "^4.3.2",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
